{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://bestspark.org/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Frame-Options", "value": "ALLOW" }
      ]
    }
  ]
}
